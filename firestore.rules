rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - id: string (required)
    //   - email: string (required)
    //   - name: string (required)
    //   - geminiApiKey: string (optional)
    //   - pinterestAccounts: list (optional)
    //   - createdAt: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'email', 'name']) &&
             data.id is string &&
             data.email is string &&
             data.name is string &&
             data.name.size() > 0 && data.name.size() < 100 &&
             (!('geminiApiKey' in data) || (data.geminiApiKey is string && data.geminiApiKey.size() < 200)) &&
             (!('pinterestAccounts' in data) || data.pinterestAccounts is list);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Allow access to the default-user document without authentication
      allow read, write: if userId == 'default-user';
      
      // Keep other users protected (though they won't be used in this mode)
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
